-- Exercise 6
-- Add AnnualSalary Column
---------------------------------------------------------

ALTER TABLE Employees
ADD AnnualSalary DECIMAL(10,2);

---------------------------------------------------------
-- AFTER UPDATE Trigger
---------------------------------------------------------

CREATE TRIGGER trg_UpdateAnnualSalary
ON Employees
AFTER UPDATE
AS
BEGIN

    UPDATE Employees

    SET AnnualSalary = Salary * 12

    WHERE EmployeeID IN
    (
        SELECT EmployeeID
        FROM inserted
    );

END;
GO

