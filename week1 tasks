-- Exercise 2
-- INSTEAD OF DELETE Trigger
---------------------------------------------------------

CREATE TRIGGER trg_PreventDelete
ON Employees
INSTEAD OF DELETE
AS
BEGIN

    RAISERROR
    (
        'Employee records cannot be deleted.',
        16,
        1
    );

END;
GO

---------------------------------------------------------
-- Test Delete Trigger
---------------------------------------------------------

DELETE FROM Employees
WHERE EmployeeID = 1;

---------------------------------------------------------
-- Exercise 3
-- LOGON Trigger
---------------------------------------------------------

CREATE TRIGGER trg_LoginRestriction
ON ALL SERVER
FOR LOGON
AS
BEGIN

    IF DATEPART(HOUR, GETDATE()) >= 2
       AND DATEPART(HOUR, GETDATE()) < 3

    BEGIN

        ROLLBACK;

    END

END;
GO

